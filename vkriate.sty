% автоматическая нумерация листингов
\newfloat{Program}{phb}{lop}
\floatname{Program}{Листинг}
\floatstyle{ruled}

%\captionsetup[Program]{justification=centering} % подпись к листингу - по центру
\captionsetup[Program]{justification=raggedright} % подпись к листингу - слева, команду \caption следует размещать вверху

% Окружение для листингов
% использование:
% \begin{MyList}{Название листинга}{Метка листинга для ссылки в тексте, напр., lst:10}
% \begin{MyCode}
% код вставляется сюда
%\end{MyCode}
% \end{MyList}
\newenvironment{MyList}[2]
  {\begin{flushleft}\needspace{3\baselineskip}\captionof{Program}{#1}\label{#2}}
  {\end{flushleft}}

\setlength{\parindent}{1.25cm} % абзацный отступ в соответствии с ГОСТ

\setcounter{secnumdepth}{3} % глубина нумерации до подразделов

